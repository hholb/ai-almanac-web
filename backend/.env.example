# Copy to .env and fill in values for local development.
# All fields are optional in stub mode — the server runs without any of these set.

DB_PATH=./almanac.db
UPLOAD_DIR=./uploads
FRONTEND_URL=http://localhost:5173
CORS_ALLOW_ALL=false  # set to true for development when frontend domain is unknown

# The Globus client ID used by the frontend (becomes JWT audience for id_token verification)
GLOBUS_CLIENT_ID=
# Reserved for future Globus Transfer API polling — not used for auth
GLOBUS_CLIENT_SECRET=

# Required when GCS signed URLs replace the local upload endpoint
GCS_BUCKET_DATA=
