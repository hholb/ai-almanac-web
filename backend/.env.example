# Copy this file to .env and fill in values for your local setup.
# .env is gitignored — never commit real credentials.

# ---------------------------------------------------------------------------
# Database
# Default is SQLite — no setup required for local dev.
# ---------------------------------------------------------------------------
DATABASE_URL=sqlite:///./almanac.db

# ---------------------------------------------------------------------------
# Storage backend
# "local" uses the filesystem paths below.
# Set to "gcs" only when testing against real GCP buckets.
# ---------------------------------------------------------------------------
STORAGE_BACKEND=local
UPLOAD_DIR=./uploads
JOB_OUTPUTS_DIR=./job_outputs

# ---------------------------------------------------------------------------
# Job runner
# "docker" runs ROMP locally. Requires Docker and the romp image to be built.
# Set to "batch" only when testing against real GCP Cloud Batch.
# ---------------------------------------------------------------------------
JOB_RUNNER=docker
ROMP_IMAGE=romp:latest
JOB_TIMEOUT_SECONDS=3600

# ---------------------------------------------------------------------------
# Auth
# Leave GLOBUS_CLIENT_ID empty to run in stub mode:
# the raw Bearer token value is used as the user ID (handy for curl testing).
# ---------------------------------------------------------------------------
FRONTEND_URL=http://localhost:5173
CORS_ALLOW_ALL=true
GLOBUS_CLIENT_ID=
GLOBUS_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Demo dataset obs directories — entries defined in backend/app/config/datasets.yaml.
# Pattern: {ID}_OBS_DIR  (ID uppercased, hyphens → underscores)
# Paths are local filesystem paths in dev, gs:// URIs in production.
# Leave unset to hide a dataset from the UI.
# ---------------------------------------------------------------------------
TEST_ETHIOPIA_OBS_DIR=

# ---------------------------------------------------------------------------
# Model data directories — entries defined in backend/app/config/models.yaml.
# Pattern: {REGION}_{ID}_MODEL_DIR  (uppercased, hyphens → underscores)
# Leave unset to hide a model from the UI.
# ---------------------------------------------------------------------------
# Test model (synthetic testdata — run scripts/generate_test_data.py first)
TEST_FUXI_TEST_MODEL_DIR=

# India models
INDIA_AIFS_MODEL_DIR=
INDIA_AIFS_DAILY_MODEL_DIR=
INDIA_IFS_MODEL_DIR=
INDIA_NEURALGCM_MODEL_DIR=
INDIA_FUXI_MODEL_DIR=
INDIA_GRAPHCAST_MODEL_DIR=
INDIA_GENCAST_MODEL_DIR=
INDIA_FUXI_S2S_MODEL_DIR=

# Ethiopia models
ETHIOPIA_AIFS_MODEL_DIR=
ETHIOPIA_FUXI_MODEL_DIR=
ETHIOPIA_GRAPHCAST_MODEL_DIR=
ETHIOPIA_GENCAST_MODEL_DIR=

# ---------------------------------------------------------------------------
# LLM chat assistant
# Leave LLM_BASE_URL empty to disable the chat feature (returns 503).
# Any OpenAI-compatible endpoint works (OpenRouter, Ollama, vLLM, etc.).
# ---------------------------------------------------------------------------
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=claude-sonnet-4-6
LLM_TIMEOUT_SECONDS=60
CHAT_FIGURE_SIGNING_SECRET=
ENABLE_RUN_CODE=false
ENABLE_RUN_CODE_SANDBOX=false

# ---------------------------------------------------------------------------
# GCP settings — only needed when STORAGE_BACKEND=gcs or JOB_RUNNER=batch
# ---------------------------------------------------------------------------
GCP_PROJECT=
GCP_REGION=us-central1
GCS_DATA_BUCKET=
GCS_UPLOADS_BUCKET=
GCS_OUTPUTS_BUCKET=
BATCH_WORKER_SA=
