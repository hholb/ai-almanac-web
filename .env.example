# ============================================================
# AI Almanac — local dev environment
#
# Copy this to backend/.env and web/.env, then fill in the
# values marked REQUIRED. Everything else has working defaults
# for docker compose.
#
# Start the full stack: docker compose up --build
# ============================================================

# ------------------------------------------------------------
# backend/.env
# ------------------------------------------------------------

# Globus OAuth app client ID — REQUIRED for auth to work.
# Leave unset to run in stub-auth mode (any Bearer token is
# accepted as a user ID — useful for pure API testing).
GLOBUS_CLIENT_ID=

# DATABASE_URL is set automatically by docker-compose.yml to
# point at the compose postgres service. Only set this if you
# are running the backend outside of docker compose.
# DATABASE_URL=postgresql+asyncpg://almanac:almanac@localhost:5432/almanac

# Storage: keep "local" for dev. Uploads and job outputs are
# written to backend/uploads and backend/job_outputs.
STORAGE_BACKEND=local

# Job runner: keep "docker" for dev. Requires the ROMP image
# to be built locally (romp:latest).
JOB_RUNNER=docker
ROMP_IMAGE=romp:latest

# CORS: set to the URL you access the frontend on.
FRONTEND_URL=http://localhost:5173

# --- Test data (end-to-end smoke testing) ---
# Synthetic data lives in testdata/ at the repo root.
# docker compose sets these automatically. Only needed if running
# the backend outside of compose.
# Generate with: uv run scripts/generate_test_data.py
#
# DEMO_OBS_DATASETS="Test Ethiopia=/path/to/repo/testdata/ethiopia/obs"
# TEST_FUXI_MODEL_DIR=/path/to/repo/testdata/ethiopia/fuxi

# --- Real benchmark data (optional) ---
# Comma-separated "Name=path" pairs. Paths must be absolute on the host
# (bind-mounted into the ROMP container read-only).
# DEMO_OBS_DATASETS="Ethiopia (CHIRPS/IMERG)=/data/obs/ethiopia"
#
# Model directories — one per model, leave blank to exclude from registry.
# See backend/app/config/models.yaml for the full list of setting names.
# INDIA_AIFS_MODEL_DIR=/data/models/india/aifs
# ETHIOPIA_FUXI_MODEL_DIR=/data/models/ethiopia/fuxi

# ------------------------------------------------------------
# web/.env
# ------------------------------------------------------------

# Globus OAuth app client ID (same value as above).
VITE_GLOBUS_CLIENT_ID=

# Redirect URL registered with your Globus app.
VITE_GLOBUS_REDIRECT_URL=http://localhost:5173/callback

# Backend API base URL as seen from the browser.
VITE_API_URL=http://localhost:8000
